#!/usr/bin/env python3
# nuba-format  —  Code formatter for Nuba (.nu) files
# Usage:
#   nuba-format file.nu           # format in-place
#   nuba-format file.nu --check   # check without modifying
#   nuba-format file.nu --diff    # show diff
#   nuba-format *.nu              # format multiple files

import sys, os, argparse, difflib

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))

def format_source(source: str) -> str:
    """Format Nuba source code."""
    lines   = source.splitlines()
    output  = []
    indent  = 0
    indent_size = 4

    for raw in lines:
        line = raw.rstrip()

        # Blank lines — keep at most 2 consecutive
        if not line.strip():
            if output and output[-1] != '':
                output.append('')
            continue

        # Comments
        stripped = line.lstrip()
        if stripped.startswith('#'):
            output.append(' ' * (indent * indent_size) + stripped)
            continue

        # Dedent on closing brace
        if stripped.startswith('}'):
            indent = max(0, indent - 1)

        # Calculate correct indentation
        output.append(' ' * (indent * indent_size) + stripped)

        # Indent on opening brace (not inside strings)
        if stripped.endswith('{') and not stripped.startswith('#'):
            indent += 1

    # Ensure single trailing newline
    while output and output[-1] == '':
        output.pop()
    return '\n'.join(output) + '\n'


def main():
    parser = argparse.ArgumentParser(
        prog='nuba-format',
        description='Format Nuba (.nu) source files'
    )
    parser.add_argument('files',         nargs='+', help='Files to format')
    parser.add_argument('--check', '-c', action='store_true',
                        help='Exit non-zero if any file would be reformatted')
    parser.add_argument('--diff',  '-d', action='store_true',
                        help='Show diff instead of modifying')
    parser.add_argument('--indent', '-i', type=int, default=4,
                        help='Indent size (default: 4)')
    args = parser.parse_args()

    changed = 0
    errors  = 0

    for path in args.files:
        if not os.path.exists(path):
            print(f"nuba-format: {path}: file not found", file=sys.stderr)
            errors += 1
            continue
        if not path.endswith('.nu'):
            print(f"nuba-format: {path}: skipping (not a .nu file)")
            continue

        with open(path, 'r', encoding='utf-8') as f:
            original = f.read()

        formatted = format_source(original)

        if formatted == original:
            print(f"  ✓  {path} (unchanged)")
            continue

        changed += 1

        if args.diff:
            diff = difflib.unified_diff(
                original.splitlines(keepends=True),
                formatted.splitlines(keepends=True),
                fromfile=f'a/{path}',
                tofile=f'b/{path}',
            )
            sys.stdout.writelines(diff)
        elif args.check:
            print(f"  ✗  {path} (would reformat)")
        else:
            with open(path, 'w', encoding='utf-8') as f:
                f.write(formatted)
            print(f"  ✎  {path} (reformatted)")

    if args.check and changed:
        print(f"\n{changed} file(s) would be reformatted")
        sys.exit(1)

    if errors:
        sys.exit(1)

    if not args.check and not args.diff and changed:
        print(f"\n{changed} file(s) reformatted")


if __name__ == '__main__':
    main()
